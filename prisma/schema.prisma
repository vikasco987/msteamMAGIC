generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Task {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  parentTaskId    String?  
  status          String
  tags            String[] @default([])
  highlightColor  String?

  dueDate         DateTime?
  priority        String?
  projectId       String?

  assignerEmail   String?
  assigneeEmail   String?
  assignerName    String?
  assigneeName    String?
  assigneeId      String?
  assigneeIds     String[] @default([])

  createdByClerkId String
  createdByName    String?      
  createdByEmail   String?      

  attachments     String[] @default([])
  paymentProofs   String[] @default([])

  amount          Float?
  received        Float?

  paymentHistory  Json[] @default([]) // keep for transaction logs
  customFields    Json?

  phone           String?
  email           String?
  shopName        String?
  location        String?
  accountNumber   String?
  ifscCode        String?
  restId          String?
  customerName    String?
  outletName      String?
  packageAmount   String?
  startDate       String?
  endDate         String?
  timeline        String?

  aadhaarUrl      String?
  panUrl          String?
  selfieUrl       String?
  chequeUrl       String?
  menuCardUrls    String[] @default([])

  // Relations
  notes           Note[]
  subtasks        Subtask[]       @relation("TaskSubtasks")
  paymentRemarks  PaymentRemark[] // 👈 NEW relation for multiple remarks
  activities      Activity[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime?
}

model Subtask {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  completed Boolean @default(false)

  taskId    String @db.ObjectId
  task      Task   @relation("TaskSubtasks", fields: [taskId], references: [id])
}

model Note {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  content      String
  createdAt    DateTime @default(now())

  authorName   String?
  authorEmail  String?
  mentions     String[] @default([]) // Array of Clerk user IDs

  taskId       String @db.ObjectId
  task         Task   @relation(fields: [taskId], references: [id])
}

model PaymentRemark {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  remark         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime? @updatedAt

  // 👤 Author Info (from Clerk)
  authorName     String?
  authorEmail    String?
  createdById    String?   // Clerk userId of creator

  // 💰 Payment Details (linked to Task)
  paymentStatus     String?   // e.g. "pending", "partial", "paid"
  amountDiscussed   Float?    // from Task.amount (negotiated)
  amountReceived    Float?    // from Task.received or this remark

  // ⏰ Follow-ups & Deadlines
  nextFollowUpDate  DateTime? // next recovery follow-up
  followUpStatus    String?   // "scheduled", "completed", "missed"
  pendingDeadline      DateTime?
  pendingDeadlineSet   Boolean  @default(false)

  // 📞 Communication
  contactMethod     String?   // "call", "visit", "email", "whatsapp"
  contactedBy       String?   // who contacted the client
  contactOutcome    String?   // "not reachable", "negotiated", "promised date", etc.

  // ⚠️ Priority & Reasoning
  priorityLevel     String?   // "high", "medium", "low"
  pendingReason     String?   // why payment is pending (e.g., "cash flow", "dispute", "invoice issue")
  customerFeedback  String?   // any remarks from customer
  internalNotes     String?   // internal analysis or notes

  // 🔗 Relation to Task
  taskId            String   @db.ObjectId
  task              Task     @relation(fields: [taskId], references: [id])

  // 🔍 Analytics & tracking
  overdueDays       Int?      // auto-calculated: days overdue past pendingDeadline
  followUpCount     Int?      @default(0) // number of follow-ups done
  reminderSent      Boolean   @default(false) // whether reminder sent
}


model Goal {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  period          String   @unique
  revenueGoal     Float
  leadsGoal       Int
  collectionGoal  Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String   @unique
  email     String   @unique
  role      String   // "ADMIN", "MASTER", "SELLER"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}    

model Attendance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  employeeName   String?
  faceImage      String?
  location       Json?
  deviceInfo     String?

  checkIn        DateTime?
  checkOut       DateTime?

  checkInReason  String?
  checkOutReason String?

  date           DateTime        // ✅ NO default
  status         String?
  verified       Boolean   @default(false)

  workingHours   Float?
  overtimeHours  Float?
  remarks        String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

 
}

model AttendanceSummary {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @unique
  totalDays      Int      @default(0)
  presentDays    Int      @default(0)
  leaveDays      Int      @default(0)
  overtimeHours  Float    @default(0)
  updatedAt      DateTime @updatedAt
}

model DeletedPayment {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  originalTask String   // taskId from Task
  paymentData  Json     // the actual payment entry that was deleted
  deletedBy    String?  // userId / email of the person who deleted
  deletedAt    DateTime @default(now())
}

model Customer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String   @unique
  email       String?
  remark      String?
  remarks     String[]  @default([]) 
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Activity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   // "STATUS_CHANGE", "NOTE_ADDED", "PAYMENT_ADDED", "SUBTASK_TOGGLED", "TASK_UPDATED"
  content   String
  author    String
  authorId  String   // Clerk userId

  taskId    String   @db.ObjectId
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   // Clerk user ID of the recipient
  type      String   // "MENTION", "TASK_COMPLETED", "PAYMENT_ADDED"
  content   String   // The notification message
  taskId    String?  @db.ObjectId
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DynamicForm {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  isPublished     Boolean  @default(false)
  
  createdBy       String   // Clerk userId
  createdByName   String?
  
  fields          FormField[]
  responses       FormResponse[]
  internalColumns InternalColumn[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FormField {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  label       String
  type        String      // "text", "number", "date", "dropdown", etc.
  placeholder String?
  required    Boolean     @default(false)
  options     String[]    @default([]) // For dropdowns/radios
  order       Int         @default(0)

  formId      String      @db.ObjectId
  form        DynamicForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  responseValues ResponseValue[]
}

model FormResponse {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  formId          String      @db.ObjectId
  form            DynamicForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  submittedBy     String?     // Clerk userId (if logged in)
  submittedByName String?
  
  values          ResponseValue[]
  internalValues  InternalValue[]

  // Permission Controls
  visibleToRoles  String[]    @default([])
  visibleToUsers  String[]    @default([])

  submittedAt     DateTime    @default(now())
}

model ResponseValue {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  
  responseId  String      @db.ObjectId
  response    FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  fieldId     String      @db.ObjectId
  field       FormField   @relation(fields: [fieldId], references: [id])
  
  value       String      // Store as string
}

model InternalColumn {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  label           String
  type            String      // text, number, currency, date, dropdown, user, formula, checkbox, etc.
  options         Json?       // For dropdown colors and options [{label: "New", color: "#eee"}]
  order           Int         @default(0)
  
  // Advanced Settings
  isRequired      Boolean     @default(false)
  isUnique        Boolean     @default(false)
  isLocked        Boolean     @default(false)
  showInPublic    Boolean     @default(false)
  formula         String?     // For dynamic calculations
  defaultValue    String?
  settings        Json?       // Any other type-specific settings

  // Permission Controls
  visibleToRoles  String[]    @default([])
  visibleToUsers  String[]    @default([])
  
  formId          String      @db.ObjectId
  form            DynamicForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  values          InternalValue[]
}

model InternalValue {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  responseId      String      @db.ObjectId
  response        FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  columnId        String      @db.ObjectId
  column          InternalColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  value           String      @default("")
  
  // Metadata
  updatedBy       String?     // UserID
  updatedByName   String?
  updatedAt       DateTime    @updatedAt
}

model FormActivity {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  responseId      String      @db.ObjectId
  userId          String
  userName        String
  type            String      // "CELL_UPDATE", "STATUS_CHANGE", "NOTE_ADDED", "CONVERTED"
  columnName      String?
  oldValue        String?
  newValue        String?
  createdAt       DateTime    @default(now())
}

model SavedView {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  formId          String   @db.ObjectId
  conditions      Json     // Array of { colId, op, val, val2 }
  conjunction     String   // "AND" | "OR"
  createdBy       String   // Clerk userId
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
